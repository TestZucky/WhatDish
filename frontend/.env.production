# Production defaults (committed). Used by `npm run build`.
# REPLACE with your deployed backend's URL. If left as-is the app will call a
# non-existent host; if emptied it silently falls back to built-in mock data.
VITE_API_BASE_URL=https://api.whatdish.example.com

# Cloudflare Turnstile site key (public). Set this to enable bot protection on
# scans. Empty = no Turnstile. Pair it with the backend's TURNSTILE_SECRET_KEY.
VITE_TURNSTILE_SITE_KEY=
