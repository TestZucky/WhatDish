# Base URL of the WhatDish backend API.
# Leave empty to run the frontend against built-in mock data (no backend needed).
# Set it once the backend is running, e.g.:
#   VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=

# Cloudflare Turnstile site key (public). When set, scans send a Turnstile token.
# Leave empty to disable. Must match the backend's TURNSTILE_SECRET_KEY widget.
VITE_TURNSTILE_SITE_KEY=
