# WhatDish backend configuration — reference for every supported variable.
#
# Config is layered by environment. Select the env with APP_ENV (development |
# production; default: development). Precedence, highest first:
#
#   1. real environment variables
#   2. .env.<env>.local   (gitignored — per-env secrets/overrides)
#   3. .env.local         (gitignored — secrets/overrides for all envs)  <-- put keys here
#   4. .env.<env>         (committed   — non-secret per-env defaults)
#   5. .env               (committed   — non-secret shared base, optional)
#
# Quick start:  cp .env.example .env.local  and fill in your keys.
# The backend runs with NO config at all (demo menu / heuristic pronunciation),
# so the frontend is usable before you add a key.

# ── Environment ───────────────────────────────────────────────────────────────
# Usually set by the Makefile / deploy platform, not here.
APP_ENV=development

# ── Secrets (put real values in .env.local, NOT here) ─────────────────────────
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
# Cloudflare Turnstile secret key. When set, scan endpoints require a valid
# token (bot protection). Leave empty to disable (dev / local / tests).
TURNSTILE_SECRET_KEY=

# ── Models ────────────────────────────────────────────────────────────────────
# Vision model for menu extraction. Default gpt-4o-mini; set gpt-4o for accuracy.
WHATDISH_MODEL=
# Cheap model for the "is this actually a menu?" guardrail (abuse protection).
WHATDISH_GUARDRAIL_MODEL=gpt-4o-mini
# Model for pronunciation enrichment (kept cheap independently of WHATDISH_MODEL).
WHATDISH_ENRICH_MODEL=gpt-4o-mini
# Per-request OpenAI timeout in seconds (default 60).
WHATDISH_OPENAI_TIMEOUT=60
# Reject uploads larger than this (bytes) before any model call. Default 10 MB.
WHATDISH_MAX_IMAGE_BYTES=10485760
# Pre-synthesize audio for recognized dishes after a scan (instant first tap).
# Costs one TTS call per dish — set false to save. Default true.
WHATDISH_PREWARM_AUDIO=true

# ── HTTP / CORS ───────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Dev defaults to localhost; prod must be set.
WHATDISH_CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173

# ── Observability / surface area ──────────────────────────────────────────────
WHATDISH_LOG_LEVEL=DEBUG          # DEBUG in dev, INFO in prod (default)
WHATDISH_ENABLE_DOCS=true         # Swagger/ReDoc — on in dev, off in prod (default)
WHATDISH_DEBUG=true               # FastAPI debug — on in dev, off in prod (default)

# ── Text-to-speech ────────────────────────────────────────────────────────────
WHATDISH_TTS_LANG=en
# ElevenLabs (optional): if a key is set it's preferred over gTTS.
ELEVENLABS_VOICE_ID=cgSgspJ2msm6clMCkdW9
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_STABILITY=0.4
ELEVENLABS_SIMILARITY=0.85
ELEVENLABS_STYLE=0.35
