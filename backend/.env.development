# Development defaults (committed — NO SECRETS here).
# Loaded when APP_ENV=development (the default). Put API keys in .env.local.

# Cheap models to keep API spend low while iterating. gpt-4o-mini is ~30x
# cheaper than gpt-4o; both extraction and the guardrail use it in dev.
WHATDISH_MODEL=gpt-4o-mini
WHATDISH_GUARDRAIL_MODEL=gpt-4o-mini

# Permissive local origins for the Vite dev + preview servers.
WHATDISH_CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173

# Verbose logs, interactive docs on, debug behaviour on.
WHATDISH_LOG_LEVEL=DEBUG
WHATDISH_ENABLE_DOCS=true
WHATDISH_DEBUG=true

WHATDISH_TTS_LANG=en
