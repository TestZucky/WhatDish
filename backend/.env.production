# Production defaults (committed — NO SECRETS here).
# Loaded when APP_ENV=production. Secrets (OPENAI_API_KEY, ELEVENLABS_API_KEY)
# belong in .env.production.local or the platform's secret manager.

# Cheap vision model to control cost. Bump to gpt-4o for higher OCR accuracy.
WHATDISH_MODEL=gpt-4o-mini
WHATDISH_GUARDRAIL_MODEL=gpt-4o-mini
# Pronunciation enrichment stays cheap even if WHATDISH_MODEL is bumped.
WHATDISH_ENRICH_MODEL=gpt-4o-mini

# CORS MUST list the deployed frontend origin(s) — an empty list blocks browsers.
# Replace with your real domain(s), comma-separated:
WHATDISH_CORS_ORIGINS=https://whatdish.example.com

# Leaner logs, interactive docs off, debug off.
WHATDISH_LOG_LEVEL=INFO
WHATDISH_ENABLE_DOCS=false
WHATDISH_DEBUG=false

WHATDISH_TTS_LANG=en
